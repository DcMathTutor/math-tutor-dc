# Math Tutor DC – Backend Environment Variables
# ------------------------------------------------
# Copy this file to .env for local dev, OR set these directly in Render's
# "Environment" dashboard for production. Never commit .env to git.
#
# To keep your password hidden from AI assistants:
#   Set values in Render's dashboard only – never in a local file.

# ---- Existing vars (already set in Render) ----
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_TO=you@gmail.com,partner@gmail.com

# ---- New vars (admin page only) ----

# bcrypt hash of your admin password. Generate it with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_THIS_WITH_YOUR_REAL_BCRYPT_HASH

# Long random string for signing JWT session tokens. Generate it with:
#   python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=replace-with-a-long-random-string

# ---- Optional ----
# DB_PATH=/data/submissions.db  # set this if using Render's persistent disk
